<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        android:fitsSystemWindows="true">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorSurface"
            app:title="@string/app_name"
            app:subtitle="@string/app_tagline"
            app:titleTextAppearance="@style/TextAppearance.Material3.TitleLarge"
            app:subtitleTextAppearance="@style/TextAppearance.Material3.BodyMedium" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="32dp">

            <!-- ===== Status hero card ===== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/status_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="?attr/colorPrimaryContainer"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardCornerRadius="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="20dp">

                    <FrameLayout
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_status_icon">

                        <ImageView
                            android:id="@+id/status_icon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_shield_check"
                            app:tint="?attr/colorOnPrimaryContainer"
                            android:contentDescription="@null" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/status_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                            android:textColor="?attr/colorOnPrimaryContainer"
                            tools:text="Protected at home" />

                        <TextView
                            android:id="@+id/status_subtitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                            android:textColor="?attr/colorOnPrimaryContainer"
                            tools:text="You're on your trusted Wi-Fi." />
                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ===== Setup card ===== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/setup_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardCornerRadius="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_settings"
                            app:tint="?attr/colorOnSurfaceVariant"
                            android:contentDescription="@null" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:text="@string/setup_title"
                            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                            android:textColor="?attr/colorOnSurface" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginStart="36dp"
                        android:text="@string/setup_subtitle"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <!-- Step 1: Permissions -->
                    <include android:layout_height="wrap_content" android:layout_width="match_parent"
                        android:id="@+id/setup_step_permissions"
                        layout="@layout/item_setup_step" />

                    <!-- Step 2: ADB grant -->
                    <include android:layout_height="wrap_content" android:layout_width="match_parent"
                        android:id="@+id/setup_step_secure"
                        layout="@layout/item_setup_step" />

                    <!-- Step 3: Save Wi-Fi -->
                    <include android:layout_height="wrap_content" android:layout_width="match_parent"
                        android:id="@+id/setup_step_home"
                        layout="@layout/item_setup_step" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ===== Current network card ===== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardCornerRadius="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_wifi"
                            app:tint="?attr/colorOnSurfaceVariant"
                            android:contentDescription="@null" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:text="@string/current_network_title"
                            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                            android:textColor="?attr/colorOnSurface" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginStart="36dp"
                        android:text="@string/current_network_subtitle"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="16dp"
                        android:background="?attr/colorOutlineVariant" />

                    <TextView android:layout_height="wrap_content" android:layout_width="wrap_content"
                        android:text="@string/current_network_ssid"
                        style="@style/Label" />

                    <TextView android:layout_height="wrap_content" android:layout_width="match_parent"
                        android:id="@+id/current_ssid"
                        style="@style/Value"
                        tools:text="MyHomeNetwork" />

                    <TextView android:layout_height="wrap_content" android:layout_width="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/current_network_bssid"
                        style="@style/Label" />

                    <TextView android:layout_height="wrap_content" android:layout_width="match_parent"
                        android:id="@+id/current_bssid"
                        style="@style/Value"
                        android:fontFamily="monospace"
                        tools:text="aa:bb:cc:dd:ee:ff" />

                    <TextView android:layout_height="wrap_content" android:layout_width="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/current_network_decision"
                        style="@style/Label" />

                    <TextView android:layout_height="wrap_content" android:layout_width="match_parent"
                        android:id="@+id/current_decision"
                        style="@style/Value"
                        tools:text="SSID and BSSID match saved home Wi-Fi" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ===== Saved home card ===== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardCornerRadius="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_home"
                            app:tint="?attr/colorOnSurfaceVariant"
                            android:contentDescription="@null" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:text="@string/home_title"
                            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                            android:textColor="?attr/colorOnSurface" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginStart="36dp"
                        android:text="@string/home_subtitle"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="16dp"
                        android:background="?attr/colorOutlineVariant" />

                    <TextView
                        android:id="@+id/home_empty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/home_empty_state"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/home_filled_group"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView android:layout_height="wrap_content" android:layout_width="wrap_content"
                            android:text="@string/home_ssid_label"
                            style="@style/Label" />

                        <TextView android:layout_height="wrap_content" android:layout_width="match_parent"
                            android:id="@+id/home_ssid"
                            style="@style/Value"
                            tools:text="MyHomeNetwork" />

                        <TextView android:layout_height="wrap_content" android:layout_width="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="@string/home_bssids_label"
                            style="@style/Label" />

                        <com.google.android.material.chip.ChipGroup
                            android:id="@+id/home_bssid_chips"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            app:chipSpacingVertical="0dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/home_add_bssid"
                                style="@style/Widget.Material3.Button.TonalButton.Icon"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="8dp"
                                android:text="@string/home_action_add_bssid"
                                app:icon="@drawable/ic_add" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/home_clear"
                                style="@style/Widget.Material3.Button.TextButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/home_action_clear" />

                        </LinearLayout>

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="16dp"
                        android:background="?attr/colorOutlineVariant" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/home_ssid_only_label"
                                android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                                android:textColor="?attr/colorOnSurface" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/home_ssid_only_desc"
                                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                android:textColor="?attr/colorOnSurfaceVariant" />
                        </LinearLayout>

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/home_ssid_only_switch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ===== Monitoring card ===== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardCornerRadius="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_tune"
                            app:tint="?attr/colorOnSurfaceVariant"
                            android:contentDescription="@null" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:text="@string/monitor_title"
                            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                            android:textColor="?attr/colorOnSurface" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginStart="36dp"
                        android:text="@string/monitor_subtitle"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="16dp"
                        android:background="?attr/colorOutlineVariant" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView android:layout_height="wrap_content" android:layout_width="match_parent"
                                android:text="@string/monitor_switch_label"
                                android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                                android:textColor="?attr/colorOnSurface" />

                            <TextView android:layout_height="wrap_content" android:layout_width="match_parent"
                                android:layout_marginTop="2dp"
                                android:text="@string/monitor_switch_desc"
                                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                android:textColor="?attr/colorOnSurfaceVariant" />
                        </LinearLayout>

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/monitor_switch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="16dp"
                        android:background="?attr/colorOutlineVariant" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/monitor_enable"
                        style="@style/Widget.Material3.Button.Icon"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/monitor_action_enable"
                        app:icon="@drawable/ic_play" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/monitor_apply"
                        style="@style/Widget.Material3.Button.TonalButton.Icon"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/monitor_action_apply"
                        app:icon="@drawable/ic_refresh" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/monitor_disable"
                        style="@style/Widget.Material3.Button.TonalButton.Icon"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/monitor_action_disable"
                        app:icon="@drawable/ic_block" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/monitor_stop"
                        style="@style/Widget.Material3.Button.TextButton.Icon"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/monitor_action_stop"
                        app:icon="@drawable/ic_stop" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ===== Diagnostics (collapsible) ===== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardCornerRadius="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/diag_header"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="20dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_terminal"
                            app:tint="?attr/colorOnSurfaceVariant"
                            android:contentDescription="@null" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView android:layout_height="wrap_content" android:layout_width="match_parent"
                                android:text="@string/diag_title"
                                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                                android:textColor="?attr/colorOnSurface" />

                            <TextView android:layout_height="wrap_content" android:layout_width="match_parent"
                                android:text="@string/diag_subtitle"
                                android:layout_marginTop="2dp"
                                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                android:textColor="?attr/colorOnSurfaceVariant" />

                        </LinearLayout>

                        <ImageView
                            android:id="@+id/diag_chevron"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_radio_unchecked"
                            android:contentDescription="@null" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/diag_content"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="20dp"
                        android:paddingBottom="20dp"
                        android:visibility="gone">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginBottom="16dp"
                            android:background="?attr/colorOutlineVariant" />

                        <TextView android:layout_height="wrap_content" android:layout_width="wrap_content" style="@style/Label" android:text="@string/diag_perm_location" />
                        <TextView android:layout_height="wrap_content" android:layout_width="match_parent" android:id="@+id/diag_perm_loc" style="@style/Value" tools:text="Granted" />

                        <TextView android:layout_height="wrap_content" android:layout_width="wrap_content" style="@style/Label" android:layout_marginTop="8dp" android:text="@string/diag_perm_nearby" />
                        <TextView android:layout_height="wrap_content" android:layout_width="match_parent" android:id="@+id/diag_perm_nearby" style="@style/Value" tools:text="Granted" />

                        <TextView android:layout_height="wrap_content" android:layout_width="wrap_content" style="@style/Label" android:layout_marginTop="8dp" android:text="@string/diag_perm_notifications" />
                        <TextView android:layout_height="wrap_content" android:layout_width="match_parent" android:id="@+id/diag_perm_notif" style="@style/Value" tools:text="Granted" />

                        <TextView android:layout_height="wrap_content" android:layout_width="wrap_content" style="@style/Label" android:layout_marginTop="8dp" android:text="@string/diag_perm_secure_settings" />
                        <TextView android:layout_height="wrap_content" android:layout_width="match_parent" android:id="@+id/diag_perm_secure" style="@style/Value" tools:text="Granted" />

                        <TextView android:layout_height="wrap_content" android:layout_width="wrap_content" style="@style/Label" android:layout_marginTop="8dp" android:text="@string/diag_location_toggle" />
                        <TextView android:layout_height="wrap_content" android:layout_width="match_parent" android:id="@+id/diag_location_toggle" style="@style/Value" tools:text="Enabled" />

                        <TextView android:layout_height="wrap_content" android:layout_width="wrap_content" style="@style/Label" android:layout_marginTop="8dp" android:text="@string/diag_wifi_source" />
                        <TextView android:layout_height="wrap_content" android:layout_width="match_parent" android:id="@+id/diag_wifi_source" style="@style/Value" tools:text="ConnectivityManager" />

                        <TextView android:layout_height="wrap_content" android:layout_width="wrap_content" style="@style/Label" android:layout_marginTop="8dp" android:text="@string/diag_last_evaluation" />
                        <TextView android:layout_height="wrap_content" android:layout_width="match_parent" android:id="@+id/diag_last_eval" style="@style/Value" android:fontFamily="monospace" tools:text="…" />

                        <TextView android:layout_height="wrap_content" android:layout_width="wrap_content" style="@style/Label" android:layout_marginTop="8dp" android:text="@string/diag_last_apply" />
                        <TextView android:layout_height="wrap_content" android:layout_width="match_parent" android:id="@+id/diag_last_apply" style="@style/Value" android:fontFamily="monospace" tools:text="…" />

                        <TextView android:layout_height="wrap_content" android:layout_width="wrap_content" style="@style/Label" android:layout_marginTop="16dp" android:text="@string/diag_history_label" />
                        <TextView
                            android:id="@+id/diag_history"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:background="?attr/colorSurfaceContainerHigh"
                            android:fontFamily="monospace"
                            android:padding="12dp"
                            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                            android:textColor="?attr/colorOnSurface"
                            android:textIsSelectable="true"
                            tools:text="Recent decisions…" />

                        <TextView android:layout_height="wrap_content" android:layout_width="wrap_content" style="@style/Label" android:layout_marginTop="16dp" android:text="@string/package_label" />
                        <TextView android:layout_height="wrap_content" android:layout_width="match_parent" android:id="@+id/diag_package" style="@style/Value" android:fontFamily="monospace" tools:text="app.homeadbguard" />

                        <TextView
                            android:id="@+id/diag_verify_hint"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:background="?attr/colorSurfaceContainerHigh"
                            android:fontFamily="monospace"
                            android:padding="12dp"
                            android:text="@string/diag_verify_hint"
                            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                            android:textColor="?attr/colorOnSurface" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ===== About ===== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardCornerRadius="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView android:layout_height="wrap_content" android:layout_width="match_parent"
                        android:text="@string/about_title"
                        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                        android:textColor="?attr/colorOnSurface" />

                    <TextView android:layout_height="wrap_content" android:layout_width="match_parent"
                        android:layout_marginTop="6dp"
                        android:text="@string/about_body"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <TextView android:layout_height="wrap_content" android:layout_width="match_parent"
                        android:id="@+id/version_text"
                        android:layout_marginTop="12dp"
                        android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        tools:text="Version 0.3.0" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
