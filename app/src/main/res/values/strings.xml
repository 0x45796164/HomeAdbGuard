    <!-- About -->
    <string name="about_title">About</string>
    <string name="about_body">Open source, MIT licensed. No internet permission, no telemetry, no analytics. The app fails closed: if anything is uncertain, ADB over Wi-Fi is requested off.</string>
    <string name="version_label">Version %1$s</string>

